{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",             // <- важно для CommonJS
    "moduleResolution": "node",       // <- вместо bundler
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "strict": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src/**/*"]
}